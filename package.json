{
  "name": "chaoxing-auto-sign",
  "version": "3.0.0",
  "description": "Chaoxing (学习通) Auto Check-in System v3",
  "main": "build/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc && node -e \"var fs=require('fs'),p=require('path');var s='src/sdk',d='build/sdk';fs.mkdirSync(d,{recursive:true});if(fs.existsSync(s))fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)))\"",
    "start": "node build/index.js",
    "docker-start": "node build/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["chaoxing", "checkin", "学习通", "签到"],
  "author": "",
  "license": "GPL-3.0",
  "dependencies": {
    "axios": "^1.7.0",
    "axios-cookiejar-support": "^5.0.0",
    "chalk": "4",
    "cheerio": "1.0.0-rc.12",
    "jsdom": "^24.0.0",
    "tough-cookie": "^4.1.3",
    "yaml": "^2.4.0",
    "ws": "^8.16.0"
  },
  "optionalDependencies": {
    "tencentcloud-sdk-nodejs": "^4.0.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
